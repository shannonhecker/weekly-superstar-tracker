{
  "name": "weekly-superstar-functions",
  "private": true,
  "version": "0.1.0",
  "description": "Cloud Functions for Weekly Superstar / Winking Star — sheet-scan CV pipeline",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "node --test --import tsx/esm src/**/*.test.ts",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.1.1",
    "jsqr": "^1.4.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "uuid": "^11.0.0",
    "gaxios": "^7.0.0",
    "google-gax": "^5.0.0",
    "retry-request": "^8.0.0",
    "teeny-request": "^10.0.0"
  }
}

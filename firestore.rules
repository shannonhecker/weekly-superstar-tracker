rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // Helper functions — keep rule conditions readable
    // -----------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function authedUid() {
      return request.auth.uid;
    }

    function isMemberOf(boardData) {
      return isSignedIn() && authedUid() in boardData.memberIds;
    }

    function isAdminOf(boardData) {
      return isSignedIn() && boardData.adminId == authedUid();
    }

    // The keys present in this update relative to the existing doc.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Premium entitlement fields are written only by trusted server code
    // after Apple transaction validation.
    function premiumFields() {
      return [
        'premium',
        'premiumProductId',
        'premiumOriginalTransactionId',
        'premiumTransactionId',
        'premiumUnlockedAt',
        'premiumUnlockedBy',
        'premiumSource',
        'premiumEnvironment'
      ];
    }

    // Parental consent records are written at board creation and then locked.
    function parentConsentFields() {
      return [
        'parentConsentAcceptedAt',
        'parentConsentVersion',
        'parentConsentSource',
        'parentConsentUid'
      ];
    }

    function hasParentConsentRecord() {
      return request.resource.data.parentConsentAcceptedAt == request.time
        && request.resource.data.parentConsentVersion is string
        && request.resource.data.parentConsentSource is string
        && request.resource.data.parentConsentUid == authedUid();
    }

    function isPremiumBoard(boardData) {
      return boardData.keys().hasAny(['premium'])
        && boardData.premium == true;
    }

    function kidLimitFor(boardData) {
      return isPremiumBoard(boardData) ? 6 : 2;
    }

    function boardDoc(boardId) {
      return get(/databases/$(database)/documents/boards/$(boardId)).data;
    }

    function boardDocAfter(boardId) {
      return getAfter(/databases/$(database)/documents/boards/$(boardId)).data;
    }

    function boardExists(boardId) {
      return exists(/databases/$(database)/documents/boards/$(boardId));
    }

    function kidCountIncrementIsValid() {
      return changedKeys().hasOnly(['kidCount'])
        && resource.data.kidCount is int
        && request.resource.data.kidCount == resource.data.kidCount + 1
        && request.resource.data.kidCount <= kidLimitFor(resource.data);
    }

    function kidCreateIncrementsBoard(boardId) {
      let before = boardDoc(boardId);
      let after = boardDocAfter(boardId);
      return boardExists(boardId)
        && before.kidCount is int
        && after.kidCount == before.kidCount + 1
        && after.kidCount <= kidLimitFor(before)
        && request.resource.data.order == before.kidCount;
    }

    function starterKidCreateIsValid(boardId) {
      let after = boardDocAfter(boardId);
      return !boardExists(boardId)
        && isMemberOf(after)
        && after.kidCount is int
        && after.kidCount >= 1
        && after.kidCount <= kidLimitFor(after)
        && request.resource.data.order is int
        && request.resource.data.order >= 0
        && request.resource.data.order < after.kidCount;
    }

    // -----------------------------------------------------------------
    // /users/{userId} — self-only profile doc (currently unused by the
    // app but rules already permit; keep for forward-compat).
    // -----------------------------------------------------------------
    match /users/{userId} {
      allow read, write: if isSignedIn() && authedUid() == userId;
    }

    // -----------------------------------------------------------------
    // /boards/{boardId}
    //
    // Threat model the new rules close:
    //  S1 — Any authed user could previously self-add to any board's
    //       memberIds via update with `uid in request.resource.data.memberIds`.
    //  S2 — A member could rewrite adminId / shareCode / name with no
    //       field-level guard.
    //  S3 — Cloud Function redemption is implemented but cannot be deployed
    //       until the Firebase project is upgraded to Blaze. Until then,
    //       Join.jsx falls back to the client share-code lookup below.
    //       After redeemShareCode is deployed, change list to member-only and
    //       remove the non-member self-join update path.
    // -----------------------------------------------------------------
    match /boards/{boardId} {

      // List queries are required by the Spark-plan fallback in Join.jsx:
      // `where('shareCode', '==', code)`.
      allow list: if isSignedIn();

      // Single-doc read — only members can see the full board doc.
      allow get: if isMemberOf(resource.data);

      // Create — the creator must be the admin. Initial memberIds must
      // contain the admin (no creating boards on behalf of others).
      allow create: if isSignedIn()
        && request.resource.data.adminId == authedUid()
        && authedUid() in request.resource.data.memberIds
        && hasParentConsentRecord()
        && request.resource.data.kidCount is int
        && request.resource.data.kidCount >= 0
        && request.resource.data.kidCount <= 2
        && !request.resource.data.keys().hasAny(premiumFields());

      // Update — three legitimate client paths:
      //
      //   1. Admin update — admin can change any field EXCEPT adminId.
      //      Once you're admin, you stay admin until you explicitly
      //      transfer (not yet supported) or delete the board. This
      //      prevents a member with elevated permissions from a future
      //      bug from being able to demote the admin silently.
      //
      //   2. Member self-leave — an existing member can ONLY remove
      //      themselves from memberIds, no other field change. The
      //      check enforces both the diff and that the user is leaving
      //      (was in old memberIds, not in new memberIds).
      //
      //   3. Non-member self-join via share-code — temporary Spark-plan
      //      fallback until redeemShareCode can be deployed.
      //
      //   No update path lets a non-admin change adminId, shareCode,
      //   board name, or any field other than memberIds.
      allow update: if isSignedIn() && (
        (
          // Admin update — admin path
          isAdminOf(resource.data)
          && !('adminId' in changedKeys())
          && !('kidCount' in changedKeys())
          && !changedKeys().hasAny(premiumFields())
          && !changedKeys().hasAny(parentConsentFields())
        ) ||
        (
          // Kid creation transaction — members may only increment kidCount
          // by one, and only up to the board's free/premium limit.
          isMemberOf(resource.data)
          && kidCountIncrementIsValid()
        ) ||
        (
          // Member self-leave
          isMemberOf(resource.data)
          && changedKeys().hasOnly(['memberIds'])
          && !(authedUid() in request.resource.data.memberIds)
        ) ||
        (
          // Non-member self-join via share-code fallback.
          !isMemberOf(resource.data)
          && changedKeys().hasOnly(['memberIds'])
          && authedUid() in request.resource.data.memberIds
        )
      );

      // Delete — admin only.
      allow delete: if isAdminOf(resource.data);

      // -----------------------------------------------------------------
      // /boards/{boardId}/kids/{kidId} — any current board member can
      // read and write kids data. This is the family-shared use case
      // (multiple parents managing the same kid's stickers).
      // -----------------------------------------------------------------
      match /kids/{kidId} {
        allow read: if isSignedIn()
          && authedUid() in boardDoc(boardId).memberIds;
        allow create: if isSignedIn()
          && authedUid() in boardDocAfter(boardId).memberIds
          && (
            kidCreateIncrementsBoard(boardId) ||
            starterKidCreateIsValid(boardId)
          );
        allow update, delete: if isSignedIn()
          && authedUid() in boardDoc(boardId).memberIds;
      }

      // -----------------------------------------------------------------
      // /boards/{boardId}/kids/{kidId}/weekHistory/{weekKey} — same
      // permissions as kids. Forward-compat for when weekHistory moves
      // from the kid doc to a subcollection (Performance audit P5).
      // -----------------------------------------------------------------
      match /kids/{kidId}/weekHistory/{weekKey} {
        allow read, write: if isSignedIn()
          && authedUid() in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds;
      }

      // -----------------------------------------------------------------
      // /boards/{boardId}/kids/{kidId}/habits/{habitId} — daily habit
      // tracking added by the iOS Habits tab (PR-3, 2026-05-09). Same
      // member-gated permissions as weekHistory. Doc shape:
      //   { label, emoji, cadence, customDays?, completions, createdAt }
      // No PII. completions map keys are YYYY-MM-DD; iOS validates the
      // shape before constructing the field path (lib/habits/store.ts).
      // -----------------------------------------------------------------
      match /kids/{kidId}/habits/{habitId} {
        allow read, write: if isSignedIn()
          && authedUid() in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds;
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /boards/{boardId} {
      // `list` allows the share-code collection query without letting
      // non-members `get` the full board doc.
      allow list: if request.auth != null;
      allow get: if request.auth != null && request.auth.uid in resource.data.memberIds;

      allow create: if request.auth != null && request.auth.uid == request.resource.data.adminId;

      // Updates allowed for existing members, or for a user adding themselves
      // to memberIds (the share-code join flow).
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        request.auth.uid in request.resource.data.memberIds
      );

      match /kids/{kidId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds;
      }
    }
  }
}

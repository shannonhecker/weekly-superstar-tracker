rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — self-only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Boards — members can read/write; anyone authed can read to find by shareCode
    match /boards/{boardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.adminId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.memberIds
            || request.auth.uid in request.resource.data.memberIds);

      // Kids subcollection — members only
      match /kids/{kidId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds;
      }
    }
  }
}
